# Copia este archivo como .env y llena tus claves.
# Este archivo NUNCA se sube a git (está en .gitignore).

# ── Kie AI (opcional) — fondos e ilustraciones con IA ──
# Crea tu cuenta gratis en https://kie.ai
KIE_AI_API_KEY=

# ── Telegram (opcional) — recibir los sets en tu celular ──
# 1) Crea un bot con @BotFather y copia aquí el token.
# 2) Escríbele "hola" a tu bot y corre:
#      python scripts/telegram_enviar.py --proj-dir . --get-chat-id
#    para obtener tu chat id, y pégalo abajo.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
